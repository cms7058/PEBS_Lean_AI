# LeanAI 部署环境变量示例
# 复制为 .env 后填入真实值：cp .env.example .env

# ============ 必填 ============

# 订阅激活码签名密钥 — 用于校验个人版/企业版 license
# 生成方式：openssl rand -hex 32
LEANAI_LICENSE_SECRET=change-me-to-a-strong-random-string

# ============ 网络（可选）============

# 宿主机端口（默认 3742，避开已有 3000/3100/8000/8100 等项目端口）
LEANAI_HOST_PORT=3742
# 宿主机监听地址。公网暴露用 0.0.0.0；仅内网/本地用 127.0.0.1
LEANAI_BIND_ADDR=0.0.0.0

# 反向代理后的 CORS 白名单（多个用英文逗号分隔）
# 示例：LEANAI_CORS_ORIGIN=https://leanai.example.com
LEANAI_CORS_ORIGIN=

# 时区
TZ=Asia/Shanghai

# ============ LLM API Key（可选：也可以部署后在 UI 中填写）============

# CLAUDE_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# QIANWEN_API_KEY=sk-xxx

# ============ 内测邀请码登录 ============

# PEBS 云函数应用身份（由云函数侧校验时使用）
INVITE_APP_ID=pebs-Lean-ai
INVITE_APP_SECRET=change-me-in-server-env

# 发给云函数的产品标识。后端会规范为小写 productKey=lean-copilot
INVITE_PRODUCT_KEY=Lean-copilot

# 默认 PEBS 云函数地址，可按部署环境覆盖
INVITE_VERIFY_URL=https://fc-mp-ad17509f-ebae-4693-974b-769771dd93c5.next.bspapp.com/pebs-copilot-api
