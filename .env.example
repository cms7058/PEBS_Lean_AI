# LeanAI 部署环境变量示例
# 复制为 .env 后填入真实值：cp .env.example .env

# ============ 必填 ============

# 订阅激活码签名密钥 — 用于校验个人版/企业版 license
# 生成方式：openssl rand -hex 32
LEANAI_LICENSE_SECRET=change-me-to-a-strong-random-string

# ============ 网络（可选）============

# 宿主机端口（默认 3741）
LEANAI_HOST_PORT=3741
# 宿主机监听地址。公网暴露用 0.0.0.0；仅内网/本地用 127.0.0.1
LEANAI_BIND_ADDR=0.0.0.0

# 反向代理后的 CORS 白名单（多个用英文逗号分隔）
# 示例：LEANAI_CORS_ORIGIN=https://leanai.example.com
LEANAI_CORS_ORIGIN=

# 时区
TZ=Asia/Shanghai

# ============ LLM API Key（可选：也可以部署后在 UI 中填写）============

# CLAUDE_API_KEY=sk-ant-xxx
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# QIANWEN_API_KEY=sk-xxx
